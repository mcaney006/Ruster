#!/usr/bin/env bash
# Emit a sha256 manifest of all tracked source files (proof of integrity / that
# no generated blob was swapped in). Deterministic ordering.
set -u
cd "$(dirname "$0")/.."
{
  echo "# RUSTER source manifest (sha256)"
  echo "# generated by tools/make-manifest"
  find src runtime tests tools static container docs fixtures \
       -type f \( -name '*.mu' -o -name '*.md' -o -name '*.c' -o -name '*.hs' \
       -o -name '*.py' -o -name '*.css' -o -name '*.tsv' -o -name 'run-tests' \
       -o -name 'integration' -o -name 'verify-*' -o -name 'forbidden-*' \
       -o -name 'make-manifest' -o -name 'Dockerfile' -o -name 'nginx.conf' \) 2>/dev/null \
    | sort \
    | while IFS= read -r f; do
        sha256sum "$f"
      done
  for f in README.md LICENSE Makefile docker-compose.yml; do
    [ -f "$f" ] && sha256sum "$f"
  done
}
